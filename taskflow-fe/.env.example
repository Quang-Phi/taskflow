# ===========================================
# TaskFlow Frontend Environment Configuration
# ===========================================

# --- API ENDPOINT ---
REACT_APP_API_URL=http://localhost:8000/api

# --- WEBSOCKETS & BROADCASTING ---
# Choose 'reverb' for local development, or 'pusher' for production
REACT_APP_BROADCASTER=reverb

# Laravel Reverb Config (Used if REACT_APP_BROADCASTER=reverb)
REACT_APP_REVERB_APP_KEY=your_reverb_app_key
REACT_APP_REVERB_HOST=localhost
REACT_APP_REVERB_PORT=8080
REACT_APP_REVERB_SCHEME=http

# Pusher Channels Config (Alternative for Production, used if REACT_APP_BROADCASTER=pusher)
REACT_APP_PUSHER_APP_KEY=
REACT_APP_PUSHER_APP_CLUSTER=mt1
