# ==========================================
# TaskFlow Backend Environment Configuration
# ==========================================

# --- APP CONFIG ---
APP_NAME=TaskFlow
APP_ENV=local          # Set to 'production' in production
APP_KEY=
APP_DEBUG=true         # Set to 'false' in production
APP_URL=http://localhost:8000

# --- JWT AUTH ---
JWT_SECRET=some_strong_jwt_secret_key
JWT_TTL=480

# --- DATABASE CONFIG ---
# For Local/Dev MySQL:
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# For Production: Use a dedicated non-root user and a strong password!
DB_USERNAME=taskflow_user
DB_PASSWORD=your_strong_password_here

SESSION_ENCRYPT=true

# --- FILESYSTEM & STORAGE ---
# For Local Development: Set to 'public'
# For Production S3: Set to 's3'
FILESYSTEM_DISK=public

# AWS S3 Configuration (Used if FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- WEBSOCKETS & BROADCASTING ---
# For Local Development: Set to 'reverb'
# For Production: Set to 'pusher' (if using Pusher Channels) or 'reverb'
BROADCAST_CONNECTION=reverb

# Laravel Reverb Config
REVERB_APP_ID=your_reverb_app_id
REVERB_APP_KEY=your_reverb_app_key
REVERB_APP_SECRET=your_reverb_app_secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Pusher Channels Config (Alternative for Production)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# --- CORS CONFIG ---
FRONTEND_URL=http://localhost:3000

# --- BITRIX OAUTH2 INTEGRATION ---
BITRIX_URL=https://bitrix.domain.com
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_SUPER_ADMIN_ID=632

# --- AI INTEGRATION (Groq / Gemini / OpenAI) ---
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gemini-2.5-flash
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
